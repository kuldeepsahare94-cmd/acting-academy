{
  "expo": {
    "name": "Acting Academy CRM",
    "slug": "acting-academy-crm-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0F172A"
    },
    "android": {
      "package": "com.actingacademy.crm",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0F172A"
      },
      "permissions": [
        "CALL_PHONE",
        "READ_PHONE_STATE",
        "RECEIVE_BOOT_COMPLETED",
        "VIBRATE",
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#0F172A"
        }
      ],
      "expo-font"
    ],
    "extra": {
      "eas": {
        "projectId": "a506c455-220a-4d98-bc6c-8f1fa34a2c81"
      }
    },
    "owner": "kuldeep4490"
  }
}
